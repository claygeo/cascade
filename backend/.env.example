# ============================================================
#  Cascade backend configuration  (copy to .env and fill in)
# ============================================================

# --- App ---
ENVIRONMENT=development            # development | production
LOG_LEVEL=info

# --- Database (Supabase Postgres; isolated in a `cascade` schema) ---
# Use the Supabase "Session pooler" connection string (IPv4, port 5432):
#   postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DB_SCHEMA=cascade

# --- Auth (hand-rolled JWT) ---
JWT_SECRET=replace-with-64-char-random-hex      # openssl rand -hex 32
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

# --- BYOK encryption ---
# Fernet key (url-safe base64, 32 bytes):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-fernet-key

# --- LLM via OpenRouter ---
# The server key powers the rate-limited public "sample" run.
# Signed-in users can bring their own key (BYOK) for their own runs.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_DEFAULT_MODEL=openai/gpt-4o-mini
LLM_MAX_OUTPUT_TOKENS=512
LLM_REQUEST_TIMEOUT_SECONDS=60

# --- Public sample-run rate limit (per client IP) ---
SAMPLE_RUNS_PER_HOUR_PER_IP=10

# --- Worker ---
WORKER_ID=worker-local             # unique per worker instance
RUN_LEASE_SECONDS=60               # lease duration; expired leases get reclaimed
RUN_MAX_ATTEMPTS=2
WORKER_POLL_INTERVAL_SECONDS=2
HTTP_FETCH_TIMEOUT_SECONDS=20      # timeout for http_fetch steps
RUN_WORKER_IN_PROCESS=false       # true = run the worker loop inside the API (cheap single-instance deploys)

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173
